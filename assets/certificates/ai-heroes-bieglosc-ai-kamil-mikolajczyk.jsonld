{"payload":"{\"@context\":[\"https://www.w3.org/2018/credentials/v1\",\"http://data.europa.eu/snb/model/context/edc-ap\"],\"credentialProfiles\":{\"id\":\"http://data.europa.eu/snb/credential/e34929035b\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/credential/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Generic\"},\"type\":\"Concept\"},\"credentialSchema\":{\"id\":\"http://data.europa.eu/snb/model/ap/edc-generic-full\",\"type\":\"ShaclValidator2017\"},\"credentialSubject\":{\"familyName\":{\"@language\":\"pl\",\"@value\":\"Mikołajczyk\"},\"fullName\":{\"@language\":\"pl\",\"@value\":\"Kamil Mikołajczyk\"},\"givenName\":{\"@language\":\"pl\",\"@value\":\"Kamil\"},\"hasClaim\":[{\"awardedBy\":{\"awardingBody\":[{\"eIDASIdentifier\":{\"notation\":\"PL5252388265\",\"spatial\":{\"id\":\"http://publications.europa.eu/resource/authority/country/POL\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Poland\",\"pl\":\"Polska\"},\"type\":\"Concept\"}},\"homepage\":[{\"contentURL\":\"https://cloudteam.global\",\"id\":\"https://cloudteam.global/\",\"title\":{\"en\":\"Website\",\"pl\":\"Strona internetowa\"},\"type\":\"WebResource\"}],\"id\":\"urn:credentium:org:5c81ee3e34374fe69aeb64859cc08d38\",\"legalName\":{\"pl\":\"CloudTeam Sp. z o.o.\"},\"location\":[{\"address\":[{\"countryCode\":{\"id\":\"http://publications.europa.eu/resource/authority/country/POL\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Poland\",\"pl\":\"Polska\"},\"type\":\"Concept\"},\"fullAddress\":{\"id\":\"urn:credentium:note:3b9436cf-62cd-4cfe-83e0-2d370041ae4a\",\"noteLiteral\":{\"pl\":\"Plac Konesera  9, 03-736 Warszawa, PL\"},\"type\":\"Note\"}}]}],\"logo\":{\"content\":\"\",\"contentEncoding\":{\"id\":\"http://data.europa.eu/snb/encoding/6146cde7dd\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/encoding/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Base64\"},\"type\":\"Concept\"},\"contentType\":{\"id\":\"http://publications.europa.eu/resource/authority/file-type/PNG\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/file-type\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"image/png\"},\"type\":\"Concept\"},\"contentURL\":\"https://cteamcredstissuerprodew.blob.core.windows.net/issuers/31fd7e90-edac-4977-bb87-c6576837c4db.png\",\"id\":\"urn:credentium:media:0a8c0581-c8e3-4052-a699-6f26d1e52611\",\"type\":\"MediaObject\"},\"taxIdentifier\":[{\"notation\":\"PL5252388265\",\"spatial\":{\"id\":\"http://publications.europa.eu/resource/authority/country/POL\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Poland\",\"pl\":\"Polska\"},\"type\":\"Concept\"}}],\"type\":\"Organisation\"}],\"awardingDate\":\"2026-06-25T11:30:01.2548174+00:00\",\"id\":\"urn:credentium:awarding-process:67d2b30201b044d092bcc94dc50a6698\",\"type\":\"AwardingProcess\"},\"description\":{\"pl\":\"Certyfikat potwierdza ukończenie sześciu modułów ścieżki AI Heroes 2026 „Biegłość w AI”. Osoba, której wydano poświadczenie, zrealizowała uporządkowaną aktywność edukacyjną dotyczącą praktycznego i świadomego korzystania z generatywnej sztucznej inteligencji w codziennej pracy — od zrozumienia podstaw AI, przez wykorzystanie Microsoft Copilot, odpowiedzialne i bezpieczne użycie narzędzi AI, tworzenie skutecznych promptów i pracę z treściami, po zbudowanie prostego agenta w Copilot Studio. Certyfikat ścieżki jest przyznawany po ukończeniu wszystkich sześciu modułów.\\nUzyskanie certyfikatu wymagało zaliczenia wszystkich sześciu modułów ścieżki. Warunkiem zaliczenia każdego modułu było uczestnictwo w co najmniej 80% sesji oraz zaliczenie quizu sprawdzającego wiedzę, składającego się z 5–10 pytań. Nagrania sesji są dostępne po zakończeniu spotkań live i mogą służyć do zaliczenia modułu na potrzeby certyfikatu.\"},\"id\":\"urn:credentium:learning-achievement:518ecb28c8e241a1a5b20a52a528a4fb\",\"influencedBy\":[{\"awardedBy\":{\"awardingBody\":[{\"eIDASIdentifier\":{\"notation\":\"PL5252388265\",\"spatial\":{\"id\":\"http://publications.europa.eu/resource/authority/country/POL\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Poland\",\"pl\":\"Polska\"},\"type\":\"Concept\"}},\"homepage\":[{\"contentURL\":\"https://cloudteam.global\",\"id\":\"https://cloudteam.global/\",\"title\":{\"en\":\"Website\",\"pl\":\"Strona internetowa\"},\"type\":\"WebResource\"}],\"id\":\"urn:credentium:org:5c81ee3e34374fe69aeb64859cc08d38\",\"legalName\":{\"pl\":\"CloudTeam Sp. z o.o.\"},\"location\":[{\"address\":[{\"countryCode\":{\"id\":\"http://publications.europa.eu/resource/authority/country/POL\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Poland\",\"pl\":\"Polska\"},\"type\":\"Concept\"},\"fullAddress\":{\"id\":\"urn:credentium:note:3b9436cf-62cd-4cfe-83e0-2d370041ae4a\",\"noteLiteral\":{\"pl\":\"Plac Konesera  9, 03-736 Warszawa, PL\"},\"type\":\"Note\"}}]}],\"logo\":{\"content\":\"\",\"contentEncoding\":{\"id\":\"http://data.europa.eu/snb/encoding/6146cde7dd\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/encoding/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Base64\"},\"type\":\"Concept\"},\"contentType\":{\"id\":\"http://publications.europa.eu/resource/authority/file-type/PNG\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/file-type\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"image/png\"},\"type\":\"Concept\"},\"contentURL\":\"https://cteamcredstissuerprodew.blob.core.windows.net/issuers/31fd7e90-edac-4977-bb87-c6576837c4db.png\",\"id\":\"urn:credentium:media:0a8c0581-c8e3-4052-a699-6f26d1e52611\",\"type\":\"MediaObject\"},\"taxIdentifier\":[{\"notation\":\"PL5252388265\",\"spatial\":{\"id\":\"http://publications.europa.eu/resource/authority/country/POL\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Poland\",\"pl\":\"Polska\"},\"type\":\"Concept\"}}],\"type\":\"Organisation\"}],\"awardingDate\":\"2026-06-25T11:30:01.2548174+00:00\",\"id\":\"urn:credentium:awarding-process:67d2b30201b044d092bcc94dc50a6698\",\"type\":\"AwardingProcess\"},\"description\":{\"pl\":\"Ścieżka „Biegłość w AI” to aktywność edukacyjna online realizowana w ramach programu AI Heroes 2026, obejmująca sześć sesji poświęconych praktycznemu wykorzystaniu generatywnej sztucznej inteligencji w codziennej pracy. Jej celem jest przeprowadzenie osób uczestniczących od podstawowego zrozumienia AI, przez praktyczne wykorzystanie narzędzi AI i Microsoft Copilot, po samodzielne stworzenie prostego agenta w Copilot Studio — bez konieczności programowania.\\nZakres aktywności obejmuje podstawy generatywnej AI, praktyczne zastosowania Microsoft Copilot, odpowiedzialne i bezpieczne korzystanie z AI, konstruowanie skutecznych promptów, wykorzystanie AI w wyszukiwaniu informacji i tworzeniu treści oraz budowę własnego Copilota w Copilot Studio.\"},\"directedBy\":[{\"homepage\":[{\"contentURL\":\"https://cloudteam.pl\",\"id\":\"https://cloudteam.pl/\",\"type\":\"WebResource\"}],\"id\":\"urn:credentium:directing-org:5853fd37dc7b492783e5a6306f058ff5-org-0\",\"legalName\":{\"pl\":\"CloudTeam\"},\"location\":[{\"address\":[{\"countryCode\":{\"id\":\"http://publications.europa.eu/resource/authority/country/PL\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"PL\",\"pl\":\"PL\"},\"type\":\"Concept\"}}]}],\"type\":\"Organisation\"},{\"homepage\":[{\"contentURL\":\"https://www.microsoft.com/pl-pl\",\"id\":\"https://www.microsoft.com/pl-pl\",\"type\":\"WebResource\"}],\"id\":\"urn:credentium:directing-org:5853fd37dc7b492783e5a6306f058ff5-org-1\",\"legalName\":{\"pl\":\"Microsoft\"},\"location\":[{\"address\":[{\"countryCode\":{\"id\":\"http://publications.europa.eu/resource/authority/country/PL\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"PL\",\"pl\":\"PL\"},\"type\":\"Concept\"}}]}],\"type\":\"Organisation\"},{\"homepage\":[{\"contentURL\":\"https://www.lenovo.com/pl/pl/\",\"id\":\"https://www.lenovo.com/pl/pl/\",\"type\":\"WebResource\"}],\"id\":\"urn:credentium:directing-org:5853fd37dc7b492783e5a6306f058ff5-org-2\",\"legalName\":{\"pl\":\"Lenovo\"},\"location\":[{\"address\":[{\"countryCode\":{\"id\":\"http://publications.europa.eu/resource/authority/country/PL\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"PL\",\"pl\":\"PL\"},\"type\":\"Concept\"}}]}],\"type\":\"Organisation\"}],\"endedAtTime\":\"2026-05-25T00:00:00\",\"id\":\"urn:credentium:learning-activity:5853fd37dc7b492783e5a6306f058ff5\",\"specifiedBy\":{\"dcType\":[{\"id\":\"http://data.europa.eu/snb/learning-activity/bf2e3a7bae\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/learning-activity/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"pl\":\"Kursy internetowe\"},\"type\":\"Concept\"}],\"homepage\":{\"contentURL\":\"https://ai-heroes.pl/sciezka-bieglosc-w-ai/\",\"id\":\"https://ai-heroes.pl/sciezka-bieglosc-w-ai/\",\"type\":\"WebResource\"},\"id\":\"urn:credentium:learning-activity-specification:19bc77ad-8202-41b4-bb89-365b990d5d40\",\"language\":[{\"id\":\"http://publications.europa.eu/resource/authority/language/POL\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/language\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Polish\",\"pl\":\"Polski\"},\"type\":\"Concept\"}],\"mode\":[{\"id\":\"http://data.europa.eu/snb/learning-assessment/920fbb3cbe\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/learning-assessment/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"pl\":\"Online (przez internet)\"},\"type\":\"Concept\"}],\"title\":{\"pl\":\"AI Heroes 2026 : Biegłość w AI\"},\"type\":\"LearningActivitySpecification\"},\"startedAtTime\":\"2026-05-11T00:00:00\",\"temporal\":[{\"endDate\":\"2026-05-25T00:00:00\",\"id\":\"urn:credentium:period-of-time:5853fd37dc7b492783e5a6306f058ff5-period-0\",\"startDate\":\"2026-05-11T00:00:00\",\"type\":\"PeriodOfTime\"}],\"title\":{\"pl\":\"AI Heroes 2026 : Biegłość w AI\"},\"type\":\"LearningActivity\",\"workload\":\"PT6H\"}],\"specifiedBy\":{\"dcType\":[{\"id\":\"http://data.europa.eu/snb/learning-opportunity/05053c1cbe\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/learning-opportunity/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"pl\":\"Kurs\"},\"type\":\"Concept\"},{\"id\":\"http://data.europa.eu/snb/learning-opportunity/17744a2647\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/learning-opportunity/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"pl\":\"Masowy, otwarty kurs internetowy (MOOC)\"},\"type\":\"Concept\"}],\"id\":\"urn:credentium:learning-achievement-specification:e23cc34d-4320-4795-ad8d-c3688036a4c8\",\"influencedBy\":[\"urn:credentium:learning-activity-specification:19bc77ad-8202-41b4-bb89-365b990d5d40\"],\"learningOutcome\":[{\"description\":{\"pl\":\"Wyjaśnia najważniejsze pojęcia związane z generatywną sztuczną inteligencją, rozpoznaje typowe zastosowania AI w pracy oraz wskazuje sytuacje, w których modele AI mogą popełniać błędy.\"},\"id\":\"urn:credentium:learning-outcome:c28e9d49-07c1-4d0c-9f7e-1d9779b25851\",\"title\":{\"pl\":\"Rozumie podstawy generatywnej AI\"},\"type\":\"LearningOutcome\"},{\"description\":{\"pl\":\"Stosuje Copilot do pisania, analizowania, porządkowania informacji i przygotowywania pierwszych wersji materiałów w typowych zadaniach biurowych.\"},\"id\":\"urn:credentium:learning-outcome:902aa586-0d11-46e8-b2c2-719cd8c866ec\",\"title\":{\"pl\":\"Wykorzystuje Microsoft Copilot w codziennej pracy\"},\"type\":\"LearningOutcome\"},{\"description\":{\"pl\":\"Rozpoznaje ograniczenia modeli AI, weryfikuje wyniki generowane przez narzędzia AI oraz stosuje podstawowe zasady ochrony danych w codziennej pracy.\"},\"id\":\"urn:credentium:learning-outcome:df6351df-4e63-473b-8542-1dc92c26b96b\",\"title\":{\"pl\":\"Korzysta z AI w sposób odpowiedzialny i bezpieczny\"},\"type\":\"LearningOutcome\"},{\"description\":{\"pl\":\"Formułuje polecenia dla AI, doprecyzowuje kontekst, iteruje odpowiedzi i poprawia jakość rezultatów uzyskiwanych z narzędzi generatywnej AI.\"},\"id\":\"urn:credentium:learning-outcome:00f8c7af-370d-42b8-b882-40287a46649a\",\"title\":{\"pl\":\"Tworzy skuteczne prompty\"},\"type\":\"LearningOutcome\"},{\"description\":{\"pl\":\"Stosuje AI do wyszukiwania informacji, analizy materiałów oraz przygotowywania treści od briefu, przez konspekt, po gotowy materiał.\"},\"id\":\"urn:credentium:learning-outcome:1e3dae5a-41ad-439b-ae97-5af5c8ad0203\",\"title\":{\"pl\":\"Wykorzystuje AI w wyszukiwaniu informacji i tworzeniu treści\"},\"type\":\"LearningOutcome\"},{\"description\":{\"pl\":\"Opisuje podstawowy proces przejścia od korzystania z AI do stworzenia prostego agenta w Copilot Studio bez programowania.\"},\"id\":\"urn:credentium:learning-outcome:1f604135-ca24-4ca9-a35b-d8e44f4d4d68\",\"title\":{\"pl\":\"Buduje prostego agenta w Copilot Studio\"},\"type\":\"LearningOutcome\"},{\"description\":{\"pl\":\"Dobiera narzędzia i sposoby pracy z AI do typowych zadań zawodowych, dbając o jakość, bezpieczeństwo i użyteczność uzyskiwanych wyników.\"},\"id\":\"urn:credentium:learning-outcome:6364962f-811b-4a9d-9e3d-1dd2dbdce0b8\",\"title\":{\"pl\":\"Stosuje AI jako praktyczne wsparcie pracy własnej i zespołowej\"},\"type\":\"LearningOutcome\"}],\"learningOutcomeSummary\":{\"id\":\"urn:credentium:note:6e1ca108-3be5-4015-a08b-82120a8cb542\",\"noteLiteral\":{\"pl\":\"Po ukończeniu ścieżki „Biegłość w AI” potrafi świadomie wykorzystywać generatywną sztuczną inteligencję w codziennej pracy, rozumie podstawowe pojęcia i ograniczenia modeli AI, stosuje Microsoft Copilot do typowych zadań biurowych, formułuje skuteczne prompty, weryfikuje wyniki generowane przez AI, wykorzystuje AI w wyszukiwaniu informacji i tworzeniu treści oraz rozumie podstawowy proces budowy prostego agenta w Copilot Studio.\"},\"type\":\"Note\"},\"learningSetting\":{\"id\":\"http://data.europa.eu/snb/learning-setting/e207a81fc7\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/learning-setting/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"pl\":\"Edukacja pozaformalna\"},\"type\":\"Concept\"},\"mode\":[{\"id\":\"http://data.europa.eu/snb/learning-assessment/920fbb3cbe\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/learning-assessment/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"pl\":\"Online (przez internet)\"},\"type\":\"Concept\"}],\"title\":{\"pl\":\"Ukończenie ścieżki „Biegłość w AI”\"},\"type\":\"LearningAchievementSpecification\"},\"title\":{\"pl\":\"Ukończenie ścieżki „Biegłość w AI”\"},\"type\":\"LearningAchievement\"}],\"id\":\"urn:credentium:identity:5b750922-019f-4724-aea3-887919a59bba\",\"type\":\"Person\"},\"description\":{\"pl\":\"Ścieżka „Biegłość w AI” to aktywność edukacyjna online realizowana w ramach programu AI Heroes 2026, obejmująca sześć sesji poświęconych praktycznemu wykorzystaniu generatywnej sztucznej inteligencji w codziennej pracy. Jej celem jest przeprowadzenie osób uczestniczących od podstawowego zrozumienia AI, przez praktyczne wykorzystanie narzędzi AI i Microsoft Copilot, po samodzielne stworzenie prostego agenta w Copilot Studio — bez konieczności programowania.\\nZakres aktywności obejmuje podstawy generatywnej AI, praktyczne zastosowania Microsoft Copilot, odpowiedzialne i bezpieczne korzystanie z AI, konstruowanie skutecznych promptów, wykorzystanie AI w wyszukiwaniu informacji i tworzeniu treści oraz budowę własnego Copilota w Copilot Studio.\"},\"displayParameter\":{\"description\":{\"pl\":\"Ścieżka „Biegłość w AI” to aktywność edukacyjna online realizowana w ramach programu AI Heroes 2026, obejmująca sześć sesji poświęconych praktycznemu wykorzystaniu generatywnej sztucznej inteligencji w codziennej pracy. Jej celem jest przeprowadzenie osób uczestniczących od podstawowego zrozumienia AI, przez praktyczne wykorzystanie narzędzi AI i Microsoft Copilot, po samodzielne stworzenie prostego agenta w Copilot Studio — bez konieczności programowania.\\nZakres aktywności obejmuje podstawy generatywnej AI, praktyczne zastosowania Microsoft Copilot, odpowiedzialne i bezpieczne korzystanie z AI, konstruowanie skutecznych promptów, wykorzystanie AI w wyszukiwaniu informacji i tworzeniu treści oraz budowę własnego Copilota w Copilot Studio.\"},\"id\":\"urn:credentium:display-parameter:ae72f700-670a-4ce3-bc18-af2c907495eb\",\"individualDisplay\":{\"displayDetail\":{\"id\":\"urn:credentium:display-detail:7910215f-06fb-4f79-9ebb-7cce7f14c5cc\",\"image\":{\"content\":\"\",\"contentEncoding\":{\"id\":\"http://data.europa.eu/snb/encoding/6146cde7dd\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/encoding/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Base64\"},\"type\":\"Concept\"},\"contentType\":{\"id\":\"http://publications.europa.eu/resource/authority/file-type/PNG\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/file-type\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"image/png\"},\"type\":\"Concept\"},\"id\":\"urn:credentium:media:e2d1ead1-d072-44e4-9192-2266de037fe5\",\"type\":\"MediaObject\"},\"page\":1,\"type\":\"DisplayDetail\"},\"id\":\"urn:credentium:individual-display:5696f8ac-5831-4d29-b10d-02988c6a4bfe\",\"language\":{\"id\":\"http://publications.europa.eu/resource/authority/language/POL\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/language\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Polish\",\"pl\":\"Polski\"},\"type\":\"Concept\"},\"type\":\"IndividualDisplay\"},\"language\":{\"id\":\"http://publications.europa.eu/resource/authority/language/POL\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/language\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Polish\",\"pl\":\"Polski\"},\"type\":\"Concept\"},\"primaryLanguage\":{\"id\":\"http://publications.europa.eu/resource/authority/language/POL\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/language\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Polish\",\"pl\":\"Polski\"},\"type\":\"Concept\"},\"title\":{\"pl\":\"AI Heroes 2026 : Biegłość w AI\"},\"type\":\"DisplayParameter\"},\"holder\":\"urn:credentium:identity:5b750922-019f-4724-aea3-887919a59bba\",\"id\":\"urn:uuid:ef5754d8-a7a5-55d3-ac72-d953cf0142e8\",\"identifier\":[{\"id\":\"urn:uuid:9231f0d1-c879-4641-953f-4860c99a9553\",\"notation\":\"ef5754d8-a7a5-55d3-ac72-d953cf0142e8\",\"schemeName\":\"credential-id\",\"type\":\"Identifier\"}],\"issuanceDate\":\"2026-06-25T11:30:01.2548174+00:00\",\"issued\":\"2026-06-25T11:30:01.2548174+00:00\",\"issuer\":{\"eIDASIdentifier\":{\"notation\":\"PL5252388265\",\"spatial\":{\"id\":\"http://publications.europa.eu/resource/authority/country/POL\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Poland\",\"pl\":\"Polska\"},\"type\":\"Concept\"}},\"homepage\":[{\"contentURL\":\"https://cloudteam.global\",\"id\":\"https://cloudteam.global/\",\"title\":{\"en\":\"Website\",\"pl\":\"Strona internetowa\"},\"type\":\"WebResource\"}],\"id\":\"urn:credentium:org:5c81ee3e34374fe69aeb64859cc08d38\",\"legalName\":{\"pl\":\"CloudTeam Sp. z o.o.\"},\"location\":[{\"address\":[{\"countryCode\":{\"id\":\"http://publications.europa.eu/resource/authority/country/POL\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"prefLabel\":{