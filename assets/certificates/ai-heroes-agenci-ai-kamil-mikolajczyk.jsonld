{"payload":"{\"@context\":[\"https://www.w3.org/2018/credentials/v1\",\"http://data.europa.eu/snb/model/context/edc-ap\"],\"credentialProfiles\":{\"id\":\"http://data.europa.eu/snb/credential/e34929035b\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/credential/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Generic\"},\"type\":\"Concept\"},\"credentialSchema\":{\"id\":\"http://data.europa.eu/snb/model/ap/edc-generic-full\",\"type\":\"ShaclValidator2017\"},\"credentialSubject\":{\"familyName\":{\"@language\":\"pl\",\"@value\":\"Mikołajczyk\"},\"fullName\":{\"@language\":\"pl\",\"@value\":\"Kamil Mikołajczyk\"},\"givenName\":{\"@language\":\"pl\",\"@value\":\"Kamil\"},\"hasClaim\":[{\"awardedBy\":{\"awardingBody\":[{\"eIDASIdentifier\":{\"notation\":\"PL5252388265\",\"spatial\":{\"id\":\"http://publications.europa.eu/resource/authority/country/POL\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Poland\",\"pl\":\"Polska\"},\"type\":\"Concept\"}},\"homepage\":[{\"contentURL\":\"https://cloudteam.global\",\"id\":\"https://cloudteam.global/\",\"title\":{\"en\":\"Website\",\"pl\":\"Strona internetowa\"},\"type\":\"WebResource\"}],\"id\":\"urn:credentium:org:5c81ee3e34374fe69aeb64859cc08d38\",\"legalName\":{\"pl\":\"CloudTeam Sp. z o.o.\"},\"location\":[{\"address\":[{\"countryCode\":{\"id\":\"http://publications.europa.eu/resource/authority/country/POL\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Poland\",\"pl\":\"Polska\"},\"type\":\"Concept\"},\"fullAddress\":{\"id\":\"urn:credentium:note:854878f4-5d37-479a-ab14-b7cb35208c29\",\"noteLiteral\":{\"pl\":\"Plac Konesera  9, 03-736 Warszawa, PL\"},\"type\":\"Note\"}}]}],\"logo\":{\"content\":\"\",\"contentEncoding\":{\"id\":\"http://data.europa.eu/snb/encoding/6146cde7dd\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/encoding/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Base64\"},\"type\":\"Concept\"},\"contentType\":{\"id\":\"http://publications.europa.eu/resource/authority/file-type/PNG\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/file-type\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"image/png\"},\"type\":\"Concept\"},\"contentURL\":\"https://cteamcredstissuerprodew.blob.core.windows.net/issuers/31fd7e90-edac-4977-bb87-c6576837c4db.png\",\"id\":\"urn:credentium:media:edbd32f4-55a3-49ab-bae0-c2b380dfcdee\",\"type\":\"MediaObject\"},\"taxIdentifier\":[{\"notation\":\"PL5252388265\",\"spatial\":{\"id\":\"http://publications.europa.eu/resource/authority/country/POL\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Poland\",\"pl\":\"Polska\"},\"type\":\"Concept\"}}],\"type\":\"Organisation\"}],\"awardingDate\":\"2026-06-23T15:36:59.764095+00:00\",\"id\":\"urn:credentium:awarding-process:11fa53441d574b87be558fdca536eaca\",\"type\":\"AwardingProcess\"},\"description\":{\"pl\":\"Certyfikat potwierdza ukończenie pięciu modułów ścieżki AI Heroes 2026 „Droga do organizacji nowej generacji: agenci AI”. Osoba, której wydano poświadczenie, zrealizowała uporządkowaną aktywność edukacyjną dotyczącą praktycznego wdrażania agentowej AI w organizacji — od identyfikacji wartościowych przypadków użycia i zrozumienia koncepcji Frontier Firm, przez budowę agentów w Copilot Studio, wykorzystanie gotowych agentów Microsoft, planowanie architektury agentów AI w Azure AI Foundry, po zastosowanie GitHub Copilot w pracy zespołów deweloperskich.\\nUzyskanie certyfikatu wymagało zaliczenia wszystkich pięciu modułów ścieżki. Warunkiem zaliczenia każdego modułu było uczestnictwo w co najmniej 80% sesji oraz uzyskanie pozytywnego wyniku w quizie sprawdzającym wiedzę, składającym się z 5–10 pytań.\"},\"id\":\"urn:credentium:learning-achievement:dbe871fe06844afa8a5f3ea1e3ec5965\",\"influencedBy\":[{\"awardedBy\":{\"awardingBody\":[{\"eIDASIdentifier\":{\"notation\":\"PL5252388265\",\"spatial\":{\"id\":\"http://publications.europa.eu/resource/authority/country/POL\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Poland\",\"pl\":\"Polska\"},\"type\":\"Concept\"}},\"homepage\":[{\"contentURL\":\"https://cloudteam.global\",\"id\":\"https://cloudteam.global/\",\"title\":{\"en\":\"Website\",\"pl\":\"Strona internetowa\"},\"type\":\"WebResource\"}],\"id\":\"urn:credentium:org:5c81ee3e34374fe69aeb64859cc08d38\",\"legalName\":{\"pl\":\"CloudTeam Sp. z o.o.\"},\"location\":[{\"address\":[{\"countryCode\":{\"id\":\"http://publications.europa.eu/resource/authority/country/POL\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Poland\",\"pl\":\"Polska\"},\"type\":\"Concept\"},\"fullAddress\":{\"id\":\"urn:credentium:note:854878f4-5d37-479a-ab14-b7cb35208c29\",\"noteLiteral\":{\"pl\":\"Plac Konesera  9, 03-736 Warszawa, PL\"},\"type\":\"Note\"}}]}],\"logo\":{\"content\":\"\",\"contentEncoding\":{\"id\":\"http://data.europa.eu/snb/encoding/6146cde7dd\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/encoding/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Base64\"},\"type\":\"Concept\"},\"contentType\":{\"id\":\"http://publications.europa.eu/resource/authority/file-type/PNG\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/file-type\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"image/png\"},\"type\":\"Concept\"},\"contentURL\":\"https://cteamcredstissuerprodew.blob.core.windows.net/issuers/31fd7e90-edac-4977-bb87-c6576837c4db.png\",\"id\":\"urn:credentium:media:edbd32f4-55a3-49ab-bae0-c2b380dfcdee\",\"type\":\"MediaObject\"},\"taxIdentifier\":[{\"notation\":\"PL5252388265\",\"spatial\":{\"id\":\"http://publications.europa.eu/resource/authority/country/POL\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Poland\",\"pl\":\"Polska\"},\"type\":\"Concept\"}}],\"type\":\"Organisation\"}],\"awardingDate\":\"2026-06-23T15:36:59.764095+00:00\",\"id\":\"urn:credentium:awarding-process:11fa53441d574b87be558fdca536eaca\",\"type\":\"AwardingProcess\"},\"description\":{\"pl\":\"Osoba uczestnicząca zrealizowała ścieżkę szkoleniową AI Heroes 2026 poświęconą praktycznemu wykorzystaniu agentowej sztucznej inteligencji w organizacji. Aktywność obejmowała pięć sesji online prowadzonych w języku polskim, łączących perspektywę biznesową i techniczną: wybór wartościowych przypadków użycia, projektowanie pierwszego agenta w Copilot Studio, wykorzystanie gotowych agentów Microsoft, planowanie architektury agentów AI w Azure AI Foundry oraz zastosowanie GitHub Copilot w pracy zespołów inżynierskich.\\nŚcieżka była przeznaczona dla osób posiadających podstawową znajomość generatywnej AI i zainteresowanych przejściem od eksperymentów z AI do praktycznego wdrażania agentów AI w organizacji.\"},\"directedBy\":[{\"homepage\":[{\"contentURL\":\"https://cloudteam.pl\",\"id\":\"https://cloudteam.pl/\",\"type\":\"WebResource\"}],\"id\":\"urn:credentium:directing-org:fe28a1c894d049099720f27139c73ba6-org-0\",\"legalName\":{\"pl\":\"CloudTeam\"},\"location\":[{\"address\":[{\"countryCode\":{\"id\":\"http://publications.europa.eu/resource/authority/country/PL\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"PL\",\"pl\":\"PL\"},\"type\":\"Concept\"}}]}],\"type\":\"Organisation\"},{\"homepage\":[{\"contentURL\":\"https://www.microsoft.com/pl-pl\",\"id\":\"https://www.microsoft.com/pl-pl\",\"type\":\"WebResource\"}],\"id\":\"urn:credentium:directing-org:fe28a1c894d049099720f27139c73ba6-org-1\",\"legalName\":{\"pl\":\"Microsoft\"},\"location\":[{\"address\":[{\"countryCode\":{\"id\":\"http://publications.europa.eu/resource/authority/country/PL\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"PL\",\"pl\":\"PL\"},\"type\":\"Concept\"}}]}],\"type\":\"Organisation\"},{\"homepage\":[{\"contentURL\":\"https://www.lenovo.com/pl/pl/\",\"id\":\"https://www.lenovo.com/pl/pl/\",\"type\":\"WebResource\"}],\"id\":\"urn:credentium:directing-org:fe28a1c894d049099720f27139c73ba6-org-2\",\"legalName\":{\"pl\":\"Lenovo\"},\"location\":[{\"address\":[{\"countryCode\":{\"id\":\"http://publications.europa.eu/resource/authority/country/PL\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"PL\",\"pl\":\"PL\"},\"type\":\"Concept\"}}]}],\"type\":\"Organisation\"}],\"endedAtTime\":\"2026-05-21T00:00:00\",\"id\":\"urn:credentium:learning-activity:fe28a1c894d049099720f27139c73ba6\",\"specifiedBy\":{\"dcType\":[{\"id\":\"http://data.europa.eu/snb/learning-activity/bf2e3a7bae\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/learning-activity/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"pl\":\"Kursy internetowe\"},\"type\":\"Concept\"}],\"homepage\":{\"contentURL\":\"https://ai-heroes.pl/sciezka-agenci/\",\"id\":\"https://ai-heroes.pl/sciezka-agenci/\",\"type\":\"WebResource\"},\"id\":\"urn:credentium:learning-activity-specification:0f30eac5-1b17-47c0-9dcc-8818c9076383\",\"language\":[{\"id\":\"http://publications.europa.eu/resource/authority/language/POL\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/language\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Polish\",\"pl\":\"Polski\"},\"type\":\"Concept\"}],\"mode\":[{\"id\":\"http://data.europa.eu/snb/learning-assessment/920fbb3cbe\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/learning-assessment/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"pl\":\"Online (przez internet)\"},\"type\":\"Concept\"}],\"title\":{\"pl\":\"AI Heroes 2026 : Droga do organizacji nowej generacji: agenci AI\"},\"type\":\"LearningActivitySpecification\"},\"startedAtTime\":\"2026-05-14T00:00:00\",\"temporal\":[{\"endDate\":\"2026-05-21T00:00:00\",\"id\":\"urn:credentium:period-of-time:fe28a1c894d049099720f27139c73ba6-period-0\",\"startDate\":\"2026-05-14T00:00:00\",\"type\":\"PeriodOfTime\"}],\"title\":{\"pl\":\"AI Heroes 2026 : Droga do organizacji nowej generacji: agenci AI\"},\"type\":\"LearningActivity\",\"workload\":\"PT5H\"}],\"specifiedBy\":{\"dcType\":[{\"id\":\"http://data.europa.eu/snb/learning-opportunity/05053c1cbe\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/learning-opportunity/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"pl\":\"Kurs\"},\"type\":\"Concept\"},{\"id\":\"http://data.europa.eu/snb/learning-opportunity/17744a2647\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/learning-opportunity/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"pl\":\"Masowy, otwarty kurs internetowy (MOOC)\"},\"type\":\"Concept\"}],\"id\":\"urn:credentium:learning-achievement-specification:adc64fcc-4021-4069-91e3-836e41dbe031\",\"influencedBy\":[\"urn:credentium:learning-activity-specification:0f30eac5-1b17-47c0-9dcc-8818c9076383\"],\"language\":[{\"id\":\"http://publications.europa.eu/resource/authority/language/POL\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/language\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Polish\",\"pl\":\"Polski\"},\"type\":\"Concept\"}],\"learningOutcome\":[{\"description\":{\"pl\":\"Rozpoznaje procesy, w których agentowa AI może realnie wnosić wartość, oraz sytuacje, w których wdrożenie agenta może być przedwczesne lub nieuzasadnione.\"},\"id\":\"urn:credentium:learning-outcome:f90c394b-ddbf-436f-b9a4-ba7f3adb1bd8\",\"title\":{\"pl\":\"Identyfikuje wartościowe przypadki użycia agentowej AI\"},\"type\":\"LearningOutcome\"},{\"description\":{\"pl\":\"Opisuje cel, logikę działania i oczekiwany rezultat agenta wspierającego konkretny proces organizacyjny.\"},\"id\":\"urn:credentium:learning-outcome:b35d8188-f720-4813-9de4-f2c01e25df5f\",\"title\":{\"pl\":\"Przekłada potrzebę organizacyjną na koncepcję agenta AI\"},\"type\":\"LearningOutcome\"},{\"description\":{\"pl\":\"Wskazuje główne etapy przejścia od pomysłu do testu pierwszego agenta w środowisku Copilot Studio.\"},\"id\":\"urn:credentium:learning-outcome:9e112dcf-af55-4d5d-9487-2a4d78c9f88c\",\"title\":{\"pl\":\"Opisuje podstawowy proces budowy i testowania agenta w Copilot Studio\"},\"type\":\"LearningOutcome\"},{\"description\":{\"pl\":\"Wskazuje, kiedy warto korzystać z gotowych agentów, takich jak Researcher i Analyst, oraz jak włączyć ich użycie do codziennych praktyk pracy.\"},\"id\":\"urn:credentium:learning-outcome:ebfc6130-2f2e-4ba9-b2f8-4013c890bded\",\"title\":{\"pl\":\"Ocenia przydatność gotowych agentów Microsoft w pracy zespołu\"},\"type\":\"LearningOutcome\"},{\"description\":{\"pl\":\"Opisuje podstawowe zagadnienia związane z architekturą, wdrożeniem, nadzorem i rozwojem agentów AI w skali organizacji.\"},\"id\":\"urn:credentium:learning-outcome:cac5fd46-df28-46be-ade4-1b1fdaefc393\",\"title\":{\"pl\":\"Wyjaśnia założenia skalowania agentów AI z wykorzystaniem Azure AI Foundry\"},\"type\":\"LearningOutcome\"},{\"description\":{\"pl\":\"Opisuje, jak GitHub Copilot wspiera pisanie kodu, refaktoryzację, testowanie, code review i codzienną pracę zespołu deweloperskiego.\"},\"id\":\"urn:credentium:learning-outcome:32f54ee0-ac64-44c9-b900-b2cdef11e02c\",\"title\":{\"pl\":\"Wskazuje praktyczne zastosowania GitHub Copilot w pracy inżynierskiej\"},\"type\":\"LearningOutcome\"},{\"description\":{\"pl\":\"Porządkuje słownik, przykłady i argumenty potrzebne do rozmowy z interesariuszami organizacji o roli agentów AI w nowoczesnym środowisku pracy.\"},\"id\":\"urn:credentium:learning-outcome:c954b85f-eb42-4b0f-9d2c-4604462410c7\",\"title\":{\"pl\":\"Komunikuje zmianę organizacyjną związaną z agentową AI\"},\"type\":\"LearningOutcome\"}],\"learningOutcomeSummary\":{\"id\":\"urn:credentium:note:6e9515e5-fd34-41c1-b9f0-fdcae89c384b\",\"noteLiteral\":{\"pl\":\"Po ukończeniu ścieżki osoba ucząca się rozumie, jak agentowa AI może być wdrażana w organizacji w sposób praktyczny, odpowiedzialny i powiązany z realną wartością biznesową. Potrafi wskazać procesy odpowiednie do automatyzacji lub wsparcia przez agentów AI, opisać podstawowe podejście do budowy agenta w Copilot Studio, rozpoznać zastosowania gotowych agentów Microsoft, wyjaśnić główne elementy architektury agentów AI w Azure AI Foundry oraz wskazać sposoby wykorzystania GitHub Copilot w pracy zespołów inżynierskich.\"},\"type\":\"Note\"},\"learningSetting\":{\"id\":\"http://data.europa.eu/snb/learning-setting/e207a81fc7\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/learning-setting/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"pl\":\"Edukacja pozaformalna\"},\"type\":\"Concept\"},\"mode\":[{\"id\":\"http://data.europa.eu/snb/learning-assessment/920fbb3cbe\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/learning-assessment/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"pl\":\"Online (przez internet)\"},\"type\":\"Concept\"}],\"title\":{\"pl\":\"Ukończenie ścieżki „Droga do organizacji nowej generacji: agenci AI”\"},\"type\":\"LearningAchievementSpecification\"},\"title\":{\"pl\":\"Ukończenie ścieżki „Droga do organizacji nowej generacji: agenci AI”\"},\"type\":\"LearningAchievement\"}],\"id\":\"urn:credentium:identity:5b750922-019f-4724-aea3-887919a59bba\",\"type\":\"Person\"},\"description\":{\"pl\":\"Osoba uczestnicząca zrealizowała ścieżkę szkoleniową AI Heroes 2026 poświęconą praktycznemu wykorzystaniu agentowej sztucznej inteligencji w organizacji. Aktywność obejmowała pięć sesji online prowadzonych w języku polskim, łączących perspektywę biznesową i techniczną: wybór wartościowych przypadków użycia, projektowanie pierwszego agenta w Copilot Studio, wykorzystanie gotowych agentów Microsoft, planowanie architektury agentów AI w Azure AI Foundry oraz zastosowanie GitHub Copilot w pracy zespołów inżynierskich.\\nŚcieżka była przeznaczona dla osób posiadających podstawową znajomość generatywnej AI i zainteresowanych przejściem od eksperymentów z AI do praktycznego wdrażania agentów AI w organizacji.\"},\"displayParameter\":{\"description\":{\"pl\":\"Osoba uczestnicząca zrealizowała ścieżkę szkoleniową AI Heroes 2026 poświęconą praktycznemu wykorzystaniu agentowej sztucznej inteligencji w organizacji. Aktywność obejmowała pięć sesji online prowadzonych w języku polskim, łączących perspektywę biznesową i techniczną: wybór wartościowych przypadków użycia, projektowanie pierwszego agenta w Copilot Studio, wykorzystanie gotowych agentów Microsoft, planowanie architektury agentów AI w Azure AI Foundry oraz zastosowanie GitHub Copilot w pracy zespołów inżynierskich.\\nŚcieżka była przeznaczona dla osób posiadających podstawową znajomość generatywnej AI i zainteresowanych przejściem od eksperymentów z AI do praktycznego wdrażania agentów AI w organizacji.\"},\"id\":\"urn:credentium:display-parameter:52c98ad9-f3ab-472c-9749-a73bc64be8d5\",\"individualDisplay\":{\"displayDetail\":{\"id\":\"urn:credentium:display-detail:1ded7d5e-0664-450b-9655-8c29ee036d77\",\"image\":{\"content\":\"\",\"contentEncoding\":{\"id\":\"http://data.europa.eu/snb/encoding/6146cde7dd\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/encoding/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Base64\"},\"type\":\"Concept\"},\"contentType\":{\"id\":\"http://publications.europa.eu/resource/authority/file-type/PNG\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/file-type\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"image/png\"},\"type\":\"Concept\"},\"id\":\"urn:credentium:media:3ffb60c8-c28a-4ba3-ab39-cf7d153d6a72\",\"type\":\"MediaObject\"},\"page\":1,\"type\":\"DisplayDetail\"},\"id\":\"urn:credentium:individual-display:37e3708e-2cbd-4534-95a7-a02947a2160f\",\"language\":{\"id\":\"http://publications.europa.eu/resource/authority/language/POL\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/language\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Polish\",\"pl\":\"Polski\"},\"type\":\"Concept\"},\"type\":\"IndividualDisplay\"},\"language\":{\"id\":\"http://publications.europa.eu/resource/authority/language/POL\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/language\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Polish\",\"pl\":\"Polski\"},\"type\":\"Concept\"},\"primaryLanguage\":{\"id\":\"http://publications.europa.eu/resource/authority/language/POL\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/language\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Polish\",\"pl\":\"Polski\"},\"type\":\"Concept\"},\"title\":{\"pl\":\"AI Heroes 2026 : Droga do organizacji nowej generacji: agenci AI\"},\"type\":\"DisplayParameter\"},\"holder\":\"urn:credentium:identity:5b750922-019f-4724-aea3-887919a59bba\",\"id\":\"urn:uuid:42786c74-0ef7-573a-955e-9ede063f83a8\",\"identifier\":[{\"id\":\"urn:uuid:18aef112-9c83-4a57-b302-d1fe07542f40\",\"notation\":\"42786c74-0ef7-573a-955e-9ede063f83a8\",\"schemeName\":\"credential-id\",\"type\":\"Identifier\"}],\"issuanceDate\":\"2026-06-23T15:36:59.764095+00:00\",\"issued\":\"2026-06-23T15:36:59.764095+00:00\",\"issuer\":{\"eIDASIdentifier\":{\"notation\":\"PL5252388265\",\"spatial\":{\"id\":\"http://publications.europa.eu/resource/authority/country/POL\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Poland\",\"pl\":\"Polska\"},\"type\":\"Concept\"}},\"homepage\":[{\"contentURL\":\"https://cloudteam.global\",\"id\":\"https://cloudteam.global/\",\"title\":{\"en\":\"Website\",\"pl\":\"Strona internetowa\"},\"type\":\"WebResource\"}],\"id\":\"urn:credentium:org:5c81ee3e34374fe69aeb64859cc08d38\",